<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rumi | Premium Branded Lawn for Kids</title>
    <style>
        /* --- General Styles --- */
        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
            background-color: #faf9f8;
            line-height: 1.6;
        }
        
        /* --- Navigation & Header --- */
        header {
            background-color: #ffffff;
            padding: 20px 0;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .logo {
            font-size: 2em;
            font-weight: bold;
            letter-spacing: 2px;
            margin-bottom: 10px;
            color: #2c3e50;
        }
        .tagline {
            font-size: 0.9em;
            color: #7f8c8d;
            margin-bottom: 15px;
        }
        nav a {
            margin: 0 15px;
            text-decoration: none;
            color: #2c3e50;
            font-weight: 500;
            transition: color 0.3s;
        }
        nav a:hover {
            color: #d35400;
        }

        /* --- Sections --- */
        section {
            padding: 60px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        h2 {
            text-align: center;
            font-size: 2.2em;
            margin-bottom: 40px;
            color: #2c3e50;
        }

        /* --- Grids --- */
        .products-grid, .fab-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }
        .card {
            background: #ffffff;
            border: 1px solid #eee;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            transition: transform 0.3s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .placeholder-img {
            width: 100%;
            height: 250px;
            background-color: #ecf0f1;
            border-radius: 4px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #bdc3c7;
        }

        /* --- Pricing & Sizes --- */
        .pricing-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
        }
        .price-box {
            background: #ffffff;
            border: 2px solid #ecf0f1;
            border-radius: 8px;
            padding: 30px;
            width: 300px;
            text-align: center;
        }
        .price-box h3 {
            margin-top: 0;
            color: #2c3e50;
        }
        .price {
            font-size: 2em;
            font-weight: bold;
            color: #d35400;
            margin: 15px 0;
        }
        .delivery-note {
            text-align: center;
            margin-top: 30px;
            font-weight: bold;
            color: #e74c3c;
        }

        /* --- Footer --- */
        footer {
            background-color: #2c3e50;
            color: #ffffff;
            text-align: center;
            padding: 30px 20px;
            margin-top: 40px;
        }
    </style>
</head>
<body>

    <!-- Header & Navigation -->
    <header>
        <div class="logo">RUMI</div>
        <div class="tagline">Premium Branded Lawn for Kids</div>
        <nav>
            <a href="#products">Shop</a>
            <a href="#fabrics">Fabrics</a>
            <a href="#sizes">Sizes</a>
            <a href="#pricing">Pricing</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- Stitched Suits Section -->
    <section id="products">
        <h2>Our Collection</h2>
        <!-- Dynamic Products Grid -->
        <div class="products-grid">
            <div class="card">
                <div class="placeholder-img">Product Image</div>
                <h3>Classic Floral 2-Piece</h3>
                <p>Ages 1 - 7 Years</p>
            </div>
            <div class="card">
                <div class="placeholder-img">Product Image</div>
                <h3>Summer Breeze Design</h3>
                <p>Ages 1 - 7 Years</p>
            </div>
            <div class="card">
                <div class="placeholder-img">Product Image</div>
                <h3>Newborn Special</h3>
                <p>Ages 0 - 1 Year</p>
            </div>
        </div>
    </section>

    <!-- Choose Your Print Section -->
    <section id="fabrics">
        <h2>Choose Your Print</h2>
        <!-- Dynamic Fabrics Grid -->
        <div class="fab-grid">
            <div class="card">
                <div class="placeholder-img">Fabric Swatch</div>
                <h3>Gul Ahmed Print 1</h3>
            </div>
            <div class="card">
                <div class="placeholder-img">Fabric Swatch</div>
                <h3>Gul Ahmed Print 2</h3>
            </div>
            <div class="card">
                <div class="placeholder-img">Fabric Swatch</div>
                <h3>Alkaram Print 1</h3>
            </div>
            <div class="card">
                <div class="placeholder-img">Fabric Swatch</div>
                <h3>Alkaram Print 2</h3>
            </div>
        </div>
    </section>

    <!-- Sizes Section -->
    <section id="sizes">
        <h2>Size Guide</h2>
        <div style="background: #fff; padding: 30px; border-radius: 8px; text-align: center; border: 1px solid #eee;">
            <p><strong>Newborn:</strong> Size 16 (0 - 1 Year)</p>
            <p><strong>Toddlers & Kids:</strong> Custom sizes available for ages 1 through 7 years.</p>
            <p><em>*We stitch to fit perfectly. Check our measurement chart upon ordering.</em></p>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing">
        <h2>Transparent Pricing</h2>
        <div class="pricing-container">
            <div class="price-box">
                <h3>Newborn Suit</h3>
                <p>Perfect for 0-1 Year (Size 16)</p>
                <div class="price">Rs. 749</div>
                <p>Premium fabric, expertly stitched.</p>
            </div>
            <div class="price-box">
                <h3>Premium Stitched Suit</h3>
                <p>Ages 1-7 Years</p>
                <div class="price">Rs. 1,699</div>
                <p>Standard and custom size options.</p>
            </div>
        </div>
        <div class="delivery-note">
            🚚 Nationwide Delivery Across Pakistan: Flat Rs. 200
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <h2>Get In Touch</h2>
        <div style="text-align: center;">
            <p>Ready to place an order or have questions about our prints?</p>
            <p><strong>Email:</strong> orders@rumikids.com</p>
            <p><strong>Phone:</strong> +92 XXX XXXXXXX</p>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Rumi Kids Clothing. All Rights Reserved.</p>
    </footer>

</body>
</html>
