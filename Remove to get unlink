<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--rose:#C2745A;--blush:#F2E8E1;--cream:#FAF6F2;--bark:#5C2E1A;--sage:#7A9473;--white:#fff;--text:#2C1A0E;--muted:#9A7B6C;--border:#E4D0C4}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}
header{background:var(--white);border-bottom:1px solid var(--border);padding:0 clamp(1rem,5vw,3rem);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;height:68px}
.logo-img{height:50px;width:auto;object-fit:contain}
.logo-fb{font-family:'Dancing Script',cursive;font-size:26px;color:var(--bark);display:none}
nav{display:flex;gap:20px}
nav a{text-decoration:none;color:var(--muted);font-size:13px;font-weight:500;transition:color .2s}
nav a:hover{color:var(--rose)}
.wa-hdr{background:#25D366;color:#fff;border:none;border-radius:24px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:7px;text-decoration:none;white-space:nowrap}
.hero{background:linear-gradient(135deg,#F9EFE9,#EDE4DC,#E5D8CE);padding:clamp(2.5rem,7vw,5rem) clamp(1rem,6vw,4rem);display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:center;min-height:460px;overflow:hidden;position:relative}
.hero::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;border-radius:50%;background:rgba(194,116,90,.08)}
.hero-tag{display:inline-block;background:var(--rose);color:#fff;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;border-radius:20px;padding:5px 14px;margin-bottom:16px}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,4.5vw,3.2rem);line-height:1.15;color:var(--bark);margin-bottom:14px}
.hero h1 span{font-style:italic;color:var(--rose)}
.hero-sub{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:24px;max-width:400px}
.hero-ctas{display:flex;gap:12px;flex-wrap:wrap}
.btn-p{background:var(--rose);color:#fff;border:none;border-radius:28px;padding:12px 24px;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 18px rgba(194,116,90,.35);transition:transform .15s}
.btn-p:hover{transform:translateY(-2px)}
.btn-s{background:transparent;color:var(--rose);border:2px solid var(--rose);border-radius:28px;padding:10px 22px;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;transition:background .15s,color .15s}
.btn-s:hover{background:var(--rose);color:#fff}
.hero-imgs{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.hero-imgs img{width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:16px;box-shadow:0 6px 24px rgba(0,0,0,.12)}
.hero-imgs img:first-child{margin-top:24px}
.trust{background:var(--bark);color:#fff;display:flex;justify-content:center;gap:clamp(1rem,4vw,3rem);padding:14px clamp(1rem,5vw,3rem);flex-wrap:wrap}
.trust span{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:500}
.sec{padding:clamp(2.5rem,6vw,4.5rem) clamp(1rem,6vw,4rem)}
.sec-alt{background:var(--blush)}
.sec-hd{text-align:center;margin-bottom:36px}
.eyebrow{font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--rose);margin-bottom:8px}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3.5vw,2.3rem);color:var(--bark);line-height:1.2}
.sec-sub{font-size:14px;color:var(--muted);margin-top:6px}
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:18px}
.wc{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px 20px;text-align:center}
.wc .i{font-size:32px;margin-bottom:12px}
.wc h3{font-family:'Playfair Display',serif;font-size:16px;color:var(--bark);margin-bottom:6px}
.wc p{font-size:13px;color:var(--muted);line-height:1.6}
.feat-wrap{padding:0 clamp(1rem,6vw,4rem) clamp(2.5rem,6vw,4rem);display:grid;grid-template-columns:1fr 1fr;gap:18px}
.feat-wrap img{width:100%;border-radius:18px;object-fit:cover;box-shadow:0 4px 20px rgba(0,0,0,.1)}
.col-banner{padding:clamp(1.5rem,4vw,2.5rem) clamp(1rem,6vw,4rem);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.col-banner h2{font-family:'Playfair Display',serif;font-size:clamp(1.3rem,3vw,2rem);color:#fff}
.col-banner p{font-size:13px;color:rgba(255,255,255,.7);margin-top:4px}
.cb-orig{background:linear-gradient(135deg,var(--bark),#3d1a08)}
.cb-new{background:linear-gradient(135deg,#1a3d2e,#0d2419)}
.new-badge{background:var(--rose);color:#fff;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:20px;padding:6px 16px;white-space:nowrap}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:22px}
.pcard{background:var(--white);border-radius:20px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.07);transition:transform .2s,box-shadow .2s}
.pcard:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(194,116,90,.18)}
.pcard-img{position:relative;overflow:hidden}
.pcard-img img.main{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;transition:transform .4s}
.pcard:hover .pcard-img img.main{transform:scale(1.04)}
.pbadge{position:absolute;top:10px;left:10px;color:#fff;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;border-radius:6px;padding:4px 9px}
.pb-a{background:var(--rose)}.pb-n{background:#2e7d32}.pb-l{background:#E07B00}.pb-o{background:#999}
.pswatch{position:absolute;bottom:10px;right:10px}
.pswatch img{width:44px;height:44px;border-radius:10px;object-fit:cover;border:2px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.18)}
.pinfo{padding:16px 16px 18px}
.pbrand{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.pname{font-family:'Playfair Display',serif;font-size:16px;color:var(--bark);margin-bottom:4px}
.ftag{display:inline-block;background:#EAF4EC;color:#3a7d4f;font-size:11px;font-weight:600;border-radius:20px;padding:3px 10px;margin-bottom:8px}
.pdesc{font-size:12px;color:var(--muted);margin-bottom:8px;line-height:1.5}
.ltag{font-size:11px;color:#7a5c2e;background:#FFF8ED;border-radius:6px;padding:4px 8px;margin-bottom:8px;display:inline-block}
.snote{font-size:12px;color:#b85c00;background:#fff3e0;border-left:3px solid #E07B00;border-radius:5px;padding:5px 9px;margin-bottom:10px;font-weight:500}
.prow{display:flex;align-items:center;justify-content:space-between;gap:8px}
.pprice{font-size:19px;font-weight:700;color:var(--rose)}
.pprice span{font-size:12px;font-weight:400;color:var(--muted)}
.obtn{background:var(--rose);color:#fff;border:none;border-radius:22px;padding:9px 16px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;text-decoration:none;transition:opacity .2s;white-space:nowrap}
.obtn:hover{opacity:.88}
.cpick{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.cpick-lbl{font-size:12px;font-weight:600;color:var(--muted)}
.cpick-dots{display:flex;gap:6px}
.cdot{width:22px;height:22px;border-radius:50%;border:2px solid transparent;cursor:pointer;padding:0;transition:transform .15s,border-color .15s}
.cdot:hover{transform:scale(1.15)}
.cdot.active{border-color:var(--bark);transform:scale(1.15);box-shadow:0 0 0 2px #fff,0 0 0 3px var(--bark)}
.cname{font-size:12px;color:var(--text);font-weight:500}
.fgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:14px}
.fcard{border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.1);position:relative;cursor:pointer}
.fcard img{width:100%;aspect-ratio:1;object-fit:cover;display:block;transition:transform .35s}
.fcard:hover img{transform:scale(1.06)}
.flbl{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(44,26,14,.75));color:#fff;font-size:11px;font-weight:600;padding:20px 10px 8px;line-height:1.3}
.size-sec{background:var(--bark);color:#fff;padding:clamp(2.5rem,6vw,4.5rem) clamp(1rem,6vw,4rem)}
.size-sec .sec-title{color:#fff}.size-sec .eyebrow{color:#E4B8A2}.size-sec .sec-sub{color:rgba(255,255,255,.65)}
.tbl-wrap{overflow-x:auto;margin-top:28px}
table{width:100%;border-collapse:collapse;font-size:14px;min-width:480px}
th{background:rgba(255,255,255,.12);padding:12px 14px;text-align:left;font-weight:600;font-size:11px;letter-spacing:.05em;text-transform:uppercase}
td{padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.85)}
tr:hover td{background:rgba(255,255,255,.05)}
.cnote{margin-top:18px;background:rgba(255,255,255,.1);border-left:3px solid var(--rose);border-radius:8px;padding:13px 16px;font-size:14px;color:rgba(255,255,255,.9)}
.ccards{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.ccard{background:var(--white);border-radius:22px;overflow:hidden;box-shadow:0 4px 24px rgba(194,116,90,.12);border:1px solid var(--border);display:flex;flex-direction:column}
.ctop{padding:24px 28px 18px;display:flex;align-items:center;gap:14px}
.ctop-s{background:linear-gradient(135deg,#FFF3E0,#FFE0B2)}.ctop-d{background:linear-gradient(135deg,#F3E5F5,#E1BEE7)}
.cemoji{font-size:34px}
.cbadge{display:inline-block;background:var(--rose);color:#fff;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border-radius:20px;padding:5px 14px}
.cbd{background:#8e44ad}
.cbody{padding:0 28px 28px;display:flex;flex-direction:column;flex:1}
.ctitle{font-family:'Playfair Display',serif;font-size:clamp(1.1rem,2.5vw,1.35rem);color:var(--bark);line-height:1.3;margin-bottom:10px}
.cdesc{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:14px}
.cpts{display:flex;flex-direction:column;gap:9px;margin-bottom:20px}
.cpt{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--text);line-height:1.5}
.cbtn{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;border:none;border-radius:26px;padding:12px 20px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;margin-top:auto}
.price-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px}
.prcard{background:var(--white);border-radius:20px;padding:28px 24px;text-align:center;border:2px solid transparent}
.prcard.feat{border-color:var(--rose);position:relative}
.prcard.feat::before{content:'Most Popular';position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--rose);color:#fff;font-size:10px;font-weight:700;padding:4px 14px;border-radius:20px}
.pr-lbl{font-size:12px;color:var(--muted);font-weight:500;margin-bottom:8px;text-transform:uppercase;letter-spacing:.08em}
.pr-amt{font-family:'Playfair Display',serif;font-size:38px;color:var(--bark)}
.pr-amt sup{font-size:18px;vertical-align:super}
.pr-note{font-size:11px;color:var(--muted);margin-top:4px}
.pr-list{list-style:none;margin:18px 0;text-align:left}
.pr-list li{font-size:13px;color:var(--text);padding:6px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.pr-list li::before{content:'✓';color:var(--sage);font-weight:700}
.contact-sec{padding:clamp(2.5rem,6vw,4.5rem) clamp(1rem,6vw,4rem);text-align:center}
.cc-wrap{display:flex;justify-content:center;gap:18px;flex-wrap:wrap;margin-top:28px}
.cc{background:var(--white);border:1px solid var(--border);border-radius:18px;padding:24px 28px;min-width:180px;text-decoration:none;color:inherit;transition:box-shadow .2s,transform .2s;display:block}
.cc:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(194,116,90,.18)}
.cc .cci{font-size:30px;margin-bottom:10px}
.cc h3{font-size:14px;font-weight:600;color:var(--bark);margin-bottom:3px}
.cc p{font-size:13px;color:var(--muted)}
.big-wa{display:inline-flex;align-items:center;gap:12px;background:#25D366;color:#fff;border:none;border-radius:36px;padding:15px 30px;font-size:16px;font-weight:700;cursor:pointer;text-decoration:none;margin-top:28px;box-shadow:0 6px 28px rgba(37,211,102,.35);transition:transform .15s}
.big-wa:hover{transform:translateY(-2px)}
footer{background:var(--bark);color:rgba(255,255,255,.7);text-align:center;padding:24px;font-size:13px}
footer strong{color:#fff}
.mov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:999;align-items:center;justify-content:center;padding:16px}
.mov.open{display:flex}
.modal{background:var(--white);border-radius:22px;padding:28px 26px;max-width:460px;width:100%;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.25);max-height:90vh;overflow-y:auto}
.mcl{position:absolute;top:14px;right:18px;background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted)}
.modal h2{font-family:'Playfair Display',serif;color:var(--bark);margin-bottom:4px;font-size:20px}
.mdress{font-size:13px;color:var(--rose);font-weight:600;margin-bottom:16px}
.modal label{display:block;font-size:12px;font-weight:600;color:var(--text);margin-bottom:5px;margin-top:12px}
.modal input,.modal select,.modal textarea{width:100%;border:1.5px solid var(--border);border-radius:9px;padding:9px 12px;font-size:14px;font-family:inherit;color:var(--text);background:var(--cream);outline:none;transition:border-color .2s}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--rose)}
.modal textarea{resize:vertical;min-height:60px}
.msub{width:100%;margin-top:16px;background:#25D366;color:#fff;border:none;border-radius:26px;padding:13px;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px}
@media(max-width:720px){.hero{grid-template-columns:1fr}.hero-imgs{display:none}.feat-wrap{grid-template-columns:1fr}nav{display:none}.trust{gap:14px}.ccards{grid-template-columns:1fr}}
</style>
</head>
